    "publish:watch": "node tools/publish-watch.mjs",
    "devk": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=1000 vite"
  },
  "dependencies": {
    "pptxgenjs": "^3.10.0",
    "react": "^19.2.0",
